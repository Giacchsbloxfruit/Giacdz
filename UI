            local STitle = Instance.new("TextLabel", SFrame)
            STitle.Size = UDim2.new(1, -100, 0, 20)
            STitle.Position = UDim2.new(0, 12, 0, 4)
            STitle.Text = SName
            STitle.TextColor3 = Theme.Text
            STitle.Font = FontBold
            STitle.TextSize = 14
            STitle.TextXAlignment = Enum.TextXAlignment.Left
            STitle.BackgroundTransparency = 1

            if hasDesc then
                local SDesc = Instance.new("TextLabel", SFrame)
                SDesc.Size = UDim2.new(1, -100, 0, 16)
                SDesc.Position = UDim2.new(0, 12, 0, 22)
                SDesc.Text = Desc
                SDesc.TextColor3 = Theme.Muted
                SDesc.Font = FontMain
                SDesc.TextSize = 12
                SDesc.TextXAlignment = Enum.TextXAlignment.Left
                SDesc.BackgroundTransparency = 1
            end

            local ValueLabel = Instance.new("TextLabel", SFrame)
            ValueLabel.Size = UDim2.new(0, 60, 0, 20)
            ValueLabel.Position = UDim2.new(1, -72, 0, 4)
            ValueLabel.Text = tostring(Default)
            ValueLabel.TextColor3 = Theme.Text
            ValueLabel.Font = FontBold
            ValueLabel.TextSize = 13
            ValueLabel.TextXAlignment = Enum.TextXAlignment.Right
            ValueLabel.BackgroundTransparency = 1

            local SliderBar = Instance.new("TextButton", SFrame)
            SliderBar.Size = UDim2.new(1, -24, 0, 6)
            SliderBar.Position = UDim2.new(0, 12, 1, -12)
            SliderBar.BackgroundColor3 = Color3.fromRGB(55, 60, 70)
            SliderBar.Text = ""
            Instance.new("UICorner", SliderBar).CornerRadius = UDim.new(1, 0)

            local SliderFill = Instance.new("Frame", SliderBar)
            SliderFill.Size = UDim2.new((Default - Min) / (Max - Min), 0, 1, 0)
            SliderFill.BackgroundColor3 = Theme.Accent
            Instance.new("UICorner", SliderFill).CornerRadius = UDim.new(1, 0)

            table.insert(Window.AccentObjects, {Instance = SliderFill, Property = "BackgroundColor3"})

            local sliding = false
            local function updateSlider(input)
                local percentage = math.clamp((input.Position.X - SliderBar.AbsolutePosition.X) / SliderBar.AbsoluteSize.X, 0, 1)
                local Value = math.round(Min + (Max - Min) * percentage)
                ValueLabel.Text = tostring(Value)
                SliderFill.Size = UDim2.new(percentage, 0, 1, 0)
                Callback(Value)
            end

            SliderBar.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then sliding = true; updateSlider(input) end end)
            UserInputService.InputChanged:Connect(function(input) if sliding and input.UserInputType == Enum.UserInputType.MouseMovement then updateSlider(input) end end)
            UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then sliding = false end end)
        end

        -- [[ 5. DROPDOWN ]]
        function TabElements:AddDropdown(DropdownConfig)
            elementCount = elementCount + 1
            local DName = DropdownConfig.Name or "Dropdown"
            local Desc = DropdownConfig.Desc
            local Options = DropdownConfig.Options or {}
            local Default = DropdownConfig.Default or ""
            local Callback = DropdownConfig.Callback or function() end

            local hasDesc = Desc and Desc ~= ""
            local baseHeight = hasDesc and 52 or 40
            
            local DFrame = Instance.new("Frame", Scroll)
            DFrame.Size = UDim2.new(1, -5, 0, baseHeight)
            DFrame.BackgroundColor3 = Theme.Element
            DFrame.BackgroundTransparency = 0.2
            DFrame.ClipsDescendants = true
            DFrame.LayoutOrder = elementCount
            Instance.new("UICorner", DFrame).CornerRadius = UDim.new(0, 5)

            local DTitle = Instance.new("TextLabel", DFrame)
            DTitle.Size = UDim2.new(1, -150, 0, 20)
            DTitle.Position = UDim2.new(0, 12, 0, hasDesc and 5 or 10)
            DTitle.Text = DName
            DTitle.TextColor3 = Theme.Text
            DTitle.Font = FontBold
            DTitle.TextSize = 14
            DTitle.TextXAlignment = Enum.TextXAlignment.Left
            DTitle.BackgroundTransparency = 1

            if hasDesc then
                local DDesc = Instance.new("TextLabel", DFrame)
                DDesc.Size = UDim2.new(1, -150, 0, 16)
                DDesc.Position = UDim2.new(0, 12, 0, 25)
                DDesc.Text = Desc
                DDesc.TextColor3 = Theme.Muted
                DDesc.Font = FontMain
                DDesc.TextSize = 12
                DDesc.TextXAlignment = Enum.TextXAlignment.Left
                DDesc.BackgroundTransparency = 1
            end

            local DropBtn = Instance.new("TextButton", DFrame)
            DropBtn.Size = UDim2.new(0, 130, 0, 26)
            DropBtn.Position = UDim2.new(1, -142, 0, hasDesc and 13 or 7)
            DropBtn.BackgroundColor3 = Color3.fromRGB(40, 47, 56)
            DropBtn.Text = Default ~= "" and Default or "Chọn..."
            DropBtn.TextColor3 = Theme.Text
            DropBtn.Font = FontMain
            DropBtn.TextSize = 13
            Instance.new("UICorner", DropBtn).CornerRadius = UDim.new(0, 4)

            local ListContainer = Instance.new("Frame", DFrame)
            ListContainer.Position = UDim2.new(0, 12, 0, baseHeight + 5)
            ListContainer.Size = UDim2.new(1, -24, 0, #Options * 28)
            ListContainer.BackgroundTransparency = 1
            local ListLayout = Instance.new("UIListLayout", ListContainer)
            ListLayout.Padding = UDim.new(0, 3)

            DFrame.Size = UDim2.new(1, -5, 0, baseHeight)

            for _, opt in pairs(Options) do
                local OptBtn = Instance.new("TextButton", ListContainer)
                OptBtn.Size = UDim2.new(1, 0, 0, 25)
                OptBtn.BackgroundColor3 = Color3.fromRGB(34, 39, 47)
                OptBtn.Text = tostring(opt)
                OptBtn.TextColor3 = Theme.Text
                OptBtn.Font = FontMain
                OptBtn.TextSize = 13
                Instance.new("UICorner", OptBtn).CornerRadius = UDim.new(0, 4)

                OptBtn.MouseButton1Click:Connect(function()
                    DropBtn.Text = tostring(opt)
                    TweenService:Create(DFrame, TweenInfo.new(0.15, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Size = UDim2.new(1, -5, 0, baseHeight)}):Play()
                    Callback(opt)
                end)
            end

            DropBtn.MouseButton1Click:Connect(function()
                local IsClosed = (math.round(DFrame.Size.Y.Offset) == baseHeight)
                local targetHeight = IsClosed and (baseHeight + #Options * 28 + 12) or baseHeight
                TweenService:Create(DFrame, TweenInfo.new(0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Size = UDim2.new(1, -5, 0, targetHeight)}):Play()
            end)
        end

        return TabElements
    end

    return Window
end

return AuroraLib
