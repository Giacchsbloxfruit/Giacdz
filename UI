local function GetWebIcon(iconName)
    if not iconName or iconName == "" then return "" end
    local getasset = getcustomasset or getsynasset
    if not getasset or not writefile or not isfile or not makefolder then return "" end

    local folderName = "Aurora_Icons"
    local filePath = folderName .. "/" .. iconName .. ".png"
    if not isfolder(folderName) then makefolder(folderName) end

    if not isfile(filePath) then
        local url = "https://raw.githubusercontent.com/dawid-scripts/Fluent/master/src/Icons/" .. iconName .. ".png"
        pcall(function()
            local imgData = game:HttpGet(url)
            if imgData then writefile(filePath, imgData) end
        end)
    end
    return isfile(filePath) and getasset(filePath) or ""
end

