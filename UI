    function Window:SetAccent(colorName)
        if RainbowConnection then
            RainbowConnection:Disconnect()
            RainbowConnection = nil
        end

        local ColorMap = {
            ["Trắng"] = Color3.fromRGB(255, 255, 255),
            ["Tím"] = Color3.fromRGB(162, 0, 255),
            ["Hồng"] = Color3.fromRGB(255, 105, 180),
            ["Đỏ"] = Color3.fromRGB(255, 50, 50),
            ["Xanh biển"] = Color3.fromRGB(0, 140, 255),
            ["Lá"] = Color3.fromRGB(50, 255, 50),
            ["Cam"] = Color3.fromRGB(255, 115, 0),
            ["Vàng"] = Color3.fromRGB(255, 210, 0)
        }

        local function UpdateAllElements(targetColor)
            Theme.Accent = targetColor
            for _, item in pairs(Window.AccentObjects) do
                if item.Instance and item.Instance.Parent then
                    if not item.Check or item.Check() then
                        item.Instance[item.Property] = targetColor
                    end
                end
            end
        end

        if colorName == "Rainbow" then
            RainbowConnection = RunService.Heartbeat:Connect(function()
                local hue = (tick() % 4) / 4
                UpdateAllElements(Color3.fromHSV(hue, 1, 1))
            end)
        else
            local selectedColor = ColorMap[colorName] or ColorMap["Trắng"]
            UpdateAllElements(selectedColor)
        end
    end

