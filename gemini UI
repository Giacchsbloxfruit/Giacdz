function Library:CreateTab(name)
    local TabBtn = Instance.new("TextButton", self.TabList)
    TabBtn.Size = UDim2.new(1, 0, 0, 40)
    TabBtn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    TabBtn.BackgroundTransparency = 1
    TabBtn.Text = name
    TabBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
    TabBtn.Font = Enum.Font.GothamSemibold
    TabBtn.TextSize = 15
    Instance.new("UICorner", TabBtn).CornerRadius = UDim.new(0, 10)

    local Page = Instance.new("ScrollingFrame", self.Container)
    Page.Size = UDim2.size(1, 0, 1, 0)
    Page.BackgroundTransparency = 1
    Page.Visible = false
    Page.ScrollBarThickness = 2
    Page.ScrollBarImageColor3 = Color3.fromRGB(80, 80, 80)
    local PageList = Instance.new("UIListLayout", Page)
    PageList.Padding = UDim.new(0, 12)

    -- Chuyển Tab cực mịn
    TabBtn.MouseButton1Click:Connect(function()
        for i, v in pairs(self.Tabs) do
            v.Page.Visible = false
            SmoothTween(v.Btn, {BackgroundTransparency = 1, TextColor3 = Color3.fromRGB(200, 200, 200)})
        end
        Page.Visible = true
        SmoothTween(TabBtn, {BackgroundTransparency = 0.9, TextColor3 = Color3.fromRGB(255, 255, 255)})
    end)

    table.insert(self.Tabs, {Page = Page, Btn = TabBtn})
    
    -- Mặc định mở tab đầu
    if #self.Tabs == 1 then
        Page.Visible = true
        TabBtn.BackgroundTransparency = 0.9
        TabBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    end

    local Elements = {}

    -- Section (Nhóm nổi nổi)
    function Elements:CreateSection(title)
        local SecFrame = Instance.new("Frame", Page)
        SecFrame.Size = UDim2.new(1, -5, 0, 25)
        SecFrame.BackgroundTransparency = 1
        
        local SecLabel = Instance.new("TextLabel", SecFrame)
        SecLabel.Text = title:upper()
        SecLabel.Size = UDim2.new(1, 0, 1, 0)
        SecLabel.TextColor3 = Color3.fromRGB(75, 170, 255) -- Màu điểm nhấn xanh Cyan
        SecLabel.Font = Enum.Font.GothamBold
        SecLabel.TextSize = 13
        SecLabel.BackgroundTransparency = 1
        SecLabel.TextXAlignment = Enum.TextXAlignment.Left
    end

    -- Button (Nổi xịn mịn)
    function Elements:CreateButton(text, callback)
        local Btn = Instance.new("TextButton", Page)
        Btn.Size = UDim2.new(1, -10, 0, 45)
        Btn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        Btn.BackgroundTransparency = 0.94
        Btn.Text = "      " .. text
        Btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        Btn.Font = Enum.Font.Gotham
        Btn.TextSize = 14
        Btn.TextXAlignment = Enum.TextXAlignment.Left
        
        Instance.new("UICorner", Btn).CornerRadius = UDim.new(0, 12)
        local BStroke = Instance.new("UIStroke", Btn)
        BStroke.Color = Color3.fromRGB(255, 255, 255)
        BStroke.Transparency = 0.92

        Btn.MouseEnter:Connect(function() 
            SmoothTween(Btn, {BackgroundTransparency = 0.86, BackgroundColor3 = Color3.fromRGB(255, 255, 255)}) 
            SmoothTween(BStroke, {Transparency = 0.6})
        end)
        Btn.MouseLeave:Connect(function() 
            SmoothTween(Btn, {BackgroundTransparency = 0.94, BackgroundColor3 = Color3.fromRGB(255, 255, 255)}) 
            SmoothTween(BStroke, {Transparency = 0.92})
        end)
        Btn.MouseButton1Click:Connect(callback)
    end

    return Elements
end

