local function ApplyDrag(frame, parent)
    local dragging, dragInput, dragStart, startPos
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true dragStart = input.Position startPos = parent.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            parent.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    frame.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)
end

function Library.new(hubName)
    local self = setmetatable({}, Library)
    self.ScreenGui = Instance.new("ScreenGui", CoreGui)

    -- Khung chính với ảnh Anime mờ
    self.Main = Instance.new("ImageLabel", self.ScreenGui)
    self.Main.Size = UDim2.new(0, 650, 0, 400)
    self.Main.Position = UDim2.new(0.5, -325, 0.5, -200)
    self.Main.Image = "rbxassetid://13101342621" -- Ví dụ ID ảnh Anime Landscape cực đẹp
    self.Main.ScaleType = Enum.ScaleType.Crop
    self.Main.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    
    local Corner = Instance.new("UICorner", self.Main)
    Corner.CornerRadius = UDim.new(0, 12)

    -- Lớp phủ tối mờ (Tạo độ mịn cho ảnh nền)
    local Overlay = Instance.new("Frame", self.Main)
    Overlay.Size = UDim2.new(1, 0, 1, 0)
    Overlay.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    Overlay.BackgroundTransparency = 0.45
    Instance.new("UICorner", Overlay).CornerRadius = UDim.new(0, 12)

    -- Cột Sidebar (Kính mờ nổi)
    self.Sidebar = Instance.new("Frame", self.Main)
    self.Sidebar.Size = UDim2.new(0, 170, 1, -30)
    self.Sidebar.Position = UDim2.new(0, 15, 0, 15)
    self.Sidebar.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    self.Sidebar.BackgroundTransparency = 0.92
    Instance.new("UICorner", self.Sidebar).CornerRadius = UDim.new(0, 10)
    
    local SideStroke = Instance.new("UIStroke", self.Sidebar)
    SideStroke.Color = Color3.fromRGB(255, 255, 255)
    SideStroke.Transparency = 0.8

    local Title = Instance.new("TextLabel", self.Sidebar)
    Title.Text = hubName
    Title.Size = UDim2.new(1, 0, 0, 50)
    Title.TextColor3 = Color3.fromRGB(255, 255, 255)
    Title.Font = Enum.Font.GothamBold
    Title.TextSize = 18
    Title.BackgroundTransparency = 1

    self.TabHolder = Instance.new("ScrollingFrame", self.Sidebar)
    self.TabHolder.Size = UDim2.new(1, -10, 1, -60)
    self.TabHolder.Position = UDim2.new(0, 5, 0, 55)
    self.TabHolder.BackgroundTransparency = 1
    self.TabHolder.ScrollBarThickness = 0
    Instance.new("UIListLayout", self.TabHolder).Padding = UDim.new(0, 8)

    -- Khu vực hiển thị nội dung
    self.Container = Instance.new("Frame", self.Main)
    self.Container.Size = UDim2.new(1, -215, 1, -30)
    self.Container.Position = UDim2.new(0, 200, 0, 15)
    self.Container.BackgroundTransparency = 1

    self.PageLayout = Instance.new("UIPageLayout", self.Container)
    self.PageLayout.TweenTime = 0.5
    self.PageLayout.EasingStyle = Enum.EasingStyle.Exponential

    ApplyDrag(self.Main, self.Main)
    return self
end

function Library:CreateTab(name)
    local TabBtn = Instance.new("TextButton", self.TabHolder)
    TabBtn.Size = UDim2.new(1, 0, 0, 38)
    TabBtn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    TabBtn.BackgroundTransparency = 1
    TabBtn.Text = name
    TabBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
    TabBtn.Font = Enum.Font.GothamSemibold
    TabBtn.TextSize = 14
    Instance.new("UICorner", TabBtn).CornerRadius = UDim.new(0, 8)

    local Page = Instance.new("ScrollingFrame", self.Container)
    Page.Size = UDim2.new(1, 0, 1, 0)
    Page.BackgroundTransparency = 1
    Page.ScrollBarThickness = 0
    local List = Instance.new("UIListLayout", Page)
    List.Padding = UDim.new(0, 10)

    TabBtn.MouseButton1Click:Connect(function()
        self.PageLayout:JumpTo(Page)
        for _, v in pairs(self.TabHolder:GetChildren()) do
            if v:IsA("TextButton") then
                TweenService:Create(v, TweenInfo.new(0.3), {BackgroundTransparency = 1, TextColor3 = Color3.fromRGB(200, 200, 200)}):Play()
            end
        end
        TweenService:Create(TabBtn, TweenInfo.new(0.3), {BackgroundTransparency = 0.85, TextColor3 = Color3.fromRGB(255, 255, 255)}):Play()
    end)

    local Elements = {}

    -- Nút bấm kiểu "Nổi" (Floating Button)
    function Elements:CreateButton(text, callback)
        local BtnFrame = Instance.new("TextButton", Page)
        BtnFrame.Size = UDim2.new(1, -5, 0, 45)
        BtnFrame.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        BtnFrame.BackgroundTransparency = 0.95
        BtnFrame.Text = "   " .. text
        BtnFrame.TextColor3 = Color3.fromRGB(255, 255, 255)
        BtnFrame.Font = Enum.Font.Gotham
        BtnFrame.TextSize = 14
        BtnFrame.TextXAlignment = Enum.TextXAlignment.Left
        
        local CornerBtn = Instance.new("UICorner", BtnFrame)
        CornerBtn.CornerRadius = UDim.new(0, 8)
        
        local Stroke = Instance.new("UIStroke", BtnFrame)
        Stroke.Color = Color3.fromRGB(255, 255, 255)
        Stroke.Transparency = 0.9

        BtnFrame.MouseEnter:Connect(function()
            TweenService:Create(BtnFrame, TweenInfo.new(0.3), {BackgroundTransparency = 0.8, BackgroundColor3 = Color3.fromRGB(255, 255, 255)}):Play()
            TweenService:Create(Stroke, TweenInfo.new(0.3), {Transparency = 0.6}):Play()
        end)
        BtnFrame.MouseLeave:Connect(function()
            TweenService:Create(BtnFrame, TweenInfo.new(0.3), {BackgroundTransparency = 0.95, BackgroundColor3 = Color3.fromRGB(255, 255, 255)}):Play()
            TweenService:Create(Stroke, TweenInfo.new(0.3), {Transparency = 0.9}):Play()
        end)
        BtnFrame.MouseButton1Click:Connect(callback)
    end

    -- Tab nhỏ (Sub-section) nổi bật
    function Elements:CreateSection(title)
        local SecFrame = Instance.new("Frame", Page)
        SecFrame.Size = UDim2.new(1, -5, 0, 25)
        SecFrame.BackgroundTransparency = 1
        
        local SecLabel = Instance.new("TextLabel", SecFrame)
        SecLabel.Text = title
        SecLabel.Size = UDim2.new(1, 0, 1, 0)
        SecLabel.TextColor3 = Color3.fromRGB(120, 180, 255) -- Màu xanh nhẹ làm điểm nhấn
        SecLabel.Font = Enum.Font.GothamBold
        SecLabel.TextSize = 12
        SecLabel.BackgroundTransparency = 1
        SecLabel.TextXAlignment = Enum.TextXAlignment.Left
    end

    return Elements
end

